{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio — Selected Work slider (Pug + SCSS + Babel)",
  "scripts": {
    "build:html": "node scripts/render.js",
    "build:scss": "sass src/scss/main.scss dist/css/main.css --no-source-map",
    "build:js": "babel src/js -d dist/js",
    "copy:images": "copyfiles -u 1 \"src/images/**/*\" dist && copyfiles -u 1 \"data/images/**/*\" dist",
    "copy:static": "copyfiles -u 2 \"src/static/**/*\" dist",
    "build": "npm run build:html && npm run build:scss && npm run build:js && npm run copy:images && npm run copy:static",
    "watch:html": "chokidar \"src/pug/**/*.pug\" \"data/*.js\" -c \"node scripts/render.js\"",
    "watch:images": "chokidar \"src/images/**/*\" \"data/images/**/*\" \"src/static/**/*\" -c \"npm run copy:images && npm run copy:static\"",
    "watch:scss": "sass --watch src/scss/main.scss dist/css/main.css --no-source-map",
    "watch:js": "babel src/js -d dist/js -w",
    "serve": "browser-sync start --server dist --files \"dist/**/*\" --no-notify --no-open",
    "dev": "npm run build && concurrently -k \"npm:watch:html\" \"npm:watch:scss\" \"npm:watch:js\" \"npm:watch:images\" \"npm:serve\""
  },
  "browserslist": [
    "defaults"
  ],
  "devDependencies": {
    "@babel/cli": "^7.24.0",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "browser-sync": "^3.0.2",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.0.0",
    "copyfiles": "^2.4.1",
    "pug": "^3.0.3",
    "sass": "^1.89.2"
  }
}
